      "section_title": "Introduction",
      "keywords": ["input", "output", "io functions"],
      "content": "Input and Output functions allow communication between the user and the program. Input functions accept data from users, while output functions display results."
    },
    {
      "section_title": "What is Input?",
      "keywords": ["input"],
      "content": "Input refers to data entered by the user and provided to the program for processing."
    },
    {
      "section_title": "What is Output?",
      "keywords": ["output"],
      "content": "Output refers to information displayed by the program after processing data."
    },
