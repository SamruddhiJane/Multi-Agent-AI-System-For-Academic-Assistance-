      ]
    },
    {
      "section_title": "Circular Queue",
      "keywords": ["circular queue"],
      "content": "The last position is connected to the first position to improve memory utilization."
    },
    {
      "section_title": "Priority Queue",
      "keywords": ["priority queue"],
      "content": "Elements are processed according to priority."
    },
    {
      "section_title": "Deque",
