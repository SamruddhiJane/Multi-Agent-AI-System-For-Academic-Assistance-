    },
    {
      "section_title": "Peek Operation",
      "keywords": ["peek"],
      "content": "Peek displays the top element without removing it."
    },
    {
      "section_title": "Stack Overflow",
      "keywords": ["overflow"],
      "content": "Occurs when an element is inserted into a full stack."
    },
    {
      "section_title": "Stack Underflow",
